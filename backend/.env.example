# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (สำหรับ CORS)
FRONTEND_URL=http://localhost:3000

# Database Configuration (Docker MySQL)
DB_HOST=localhost
DB_USER=it_shop_user
DB_PASSWORD=it_shop_pass
DB_NAME=it_shop_db
DB_PORT=3306

# JWT Secret (สำหรับ Authentication - จะใช้ใน Phase 2)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
